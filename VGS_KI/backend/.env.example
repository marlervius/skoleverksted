# ============================================
# VGS Lærerassistent - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# --- Optional ---
# Google Gemini model (default: gemini-3.5-flash)
# Options: gemini-3.5-flash (best quality), gemini-3.1-flash-lite (cheapest)
GOOGLE_MODEL=gemini-3.5-flash

# Server port (default: 8000)
PORT=8000

# CORS allowed origins (comma-separated, leave empty for all origins in dev)
# Example: https://your-app.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=

# Agent execution timeout in seconds (default: 300 = 5 minutes)
AGENT_TIMEOUT_SECONDS=300
