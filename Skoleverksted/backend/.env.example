# Shared AI provider (required for generation)
GOOGLE_API_KEY=
AI_TEMPERATURE=0.35
PROMPT_VERSION=skoleverksted-v2

# Optional common frontend origin
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Module-specific security (MATE_API_KEY is required by the production frontend proxy)
APP_PASSWORD=
MATE_API_KEY=

# Optional persistence
DATABASE_URL=
REDIS_URL=
OUTPUT_DIR=./output
SKOLEVERKSTED_DB_PATH=./output/platform/skoleverksted.sqlite3
