# Shared AI provider (required for generation)
GOOGLE_API_KEY=
# Optional separate key for paid image calls; falls back to GOOGLE_API_KEY.
GOOGLE_IMAGE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image
AI_TEMPERATURE=0.35
PROMPT_VERSION=skoleverksted-v2

# Optional common frontend origin
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
SKOLEVERKSTED_PUBLIC_FRONTEND_URL=https://skoleverksted-3npg.vercel.app

# Module-specific security (MATE_API_KEY is required by the production frontend proxy)
APP_PASSWORD=
MATE_API_KEY=

# Optional persistence
DATABASE_URL=
REDIS_URL=
OUTPUT_DIR=./output
SKOLEVERKSTED_DB_PATH=./output/platform/skoleverksted.sqlite3

# Optional explicit executable paths (the production Docker image sets these)
TYPST_PATH=typst
PDFLATEX_PATH=pdflatex

# Keep concurrency low on memory-constrained hosts
MAX_CONCURRENT_JOBS=2
MAX_CONCURRENT_COMPILES=2
