# MateMaTeX 2.0 — Frontend Environment Variables
# Copy to .env.local for local development.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only (never NEXT_PUBLIC_): used by /api/backend and SSE/PDF proxies
# MATE_API_KEY=your-secret-key

# Optional: internal URL if backend differs from NEXT_PUBLIC_API_URL
# BACKEND_INTERNAL_URL=http://localhost:8000
